---
/**
 * ConnectingThread.astro
 *
 * Renders an SVG overlay that spans the full page height.
 * The actual path and nodes are built dynamically by src/scripts/thread.js
 * after the DOM is laid out — getBoundingClientRect on section anchors.
 *
 * The SVG uses gradientUnits="userSpaceOnUse" so the violet→green gradient
 * maps correctly across the full page height (set in JS).
 */
---

<!-- Full-page SVG thread overlay — positioned absolute, behind all content -->
<svg
  class="thread-svg"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <!--
      Gradient shifts from violet (top/hero) to deep green (bottom/footer).
      gradientUnits="userSpaceOnUse" means y1/y2 are in page pixels — set by JS.
    -->
    <linearGradient
      id="thread-gradient"
      x1="0"
      y1="0"
      x2="0"
      y2="1000"
      gradientUnits="userSpaceOnUse"
    >
      <stop offset="0%"   stop-color="#9333ea" stop-opacity="0.9" />
      <stop offset="40%"  stop-color="#7c3aed" stop-opacity="0.7" />
      <stop offset="70%"  stop-color="#047857" stop-opacity="0.7" />
      <stop offset="100%" stop-color="#10b981" stop-opacity="0.9" />
    </linearGradient>

    <!-- Glow filter for the path -->
    <filter id="thread-glow" x="-200%" y="-200%" width="500%" height="500%">
      <feGaussianBlur stdDeviation="3" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>

    <!-- Node pulse filter -->
    <filter id="node-glow" x="-300%" y="-300%" width="700%" height="700%">
      <feGaussianBlur stdDeviation="4" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <!--
    Main thread path — drawn by JS (src/scripts/thread.js).
    stroke-dasharray and stroke-dashoffset are set via GSAP.
  -->
  <path
    class="thread-path"
    d=""
    stroke="url(#thread-gradient)"
    stroke-width="1.5"
    fill="none"
    stroke-linecap="round"
    filter="url(#thread-glow)"
  />

  <!--
    Node circles at each section anchor — appended by JS.
    CSS class: .thread-node
  -->
</svg>

<!-- Mobile fallback: static dotted vertical accent line -->
<div class="thread-mobile-line" aria-hidden="true"></div>

<style>
  .thread-mobile-line {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 100%;
    background: repeating-linear-gradient(
      to bottom,
      rgba(147, 51, 234, 0.25) 0px,
      rgba(147, 51, 234, 0.25) 4px,
      transparent 4px,
      transparent 10px
    );
    pointer-events: none;
    z-index: 2;
  }
</style>
