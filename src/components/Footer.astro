---
/**
 * Footer.astro — Section 5 (100vh)
 *
 * - Dark green tint background
 * - W&S Technik GmbH company info
 * - "Part of W&S Gruppe" hierarchy indicator
 * - Minimal legal links + copyright
 */

const currentYear = new Date().getFullYear();
---

<footer class="snap-section footer" id="footer" data-section="4">
  <div class="section-inner footer-inner">

    <!-- Top row: logo + nav -->
    <div class="footer-top">

      <!-- Wordmark / logo -->
      <div class="footer-brand">
        <div class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
            <rect width="32" height="32" rx="4" fill="rgba(107,33,168,0.25)" stroke="rgba(147,51,234,0.3)" stroke-width="1"/>
            <path d="M7 10l5 6-5 6M15 22h10" stroke="#a855f7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="brand-text">
          <span class="brand-name">code.wus&#8209;technik.com</span>
          <span class="brand-tagline label">Internal Development Platform</span>
        </div>
      </div>

      <!-- Mini nav -->
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="#hero"       class="footer-nav-link">Home</a>
        <a href="#services"   class="footer-nav-link">Services</a>
        <a href="#how-we-work" class="footer-nav-link">Process</a>
        <a href="#about"      class="footer-nav-link">About</a>
      </nav>
    </div>

    <!-- Middle: company statement -->
    <div class="footer-mid">
      <div class="footer-divider" aria-hidden="true"></div>

      <div class="footer-company">
        <div class="company-primary">
          <span class="company-name">W&amp;S Technik GmbH</span>
          <span class="company-role label label--green">Software Development Department</span>
        </div>

        <div class="company-hierarchy">
          <span class="hierarchy-line" aria-label="Part of W&S Gruppe">
            <span class="hierarchy-prefix label">Part of</span>
            <span class="hierarchy-group">W&amp;S Gruppe</span>
          </span>
        </div>
      </div>

      <div class="footer-services-summary">
        <span class="svc-tag">DevOps</span>
        <span class="svc-sep" aria-hidden="true">/</span>
        <span class="svc-tag">WebOps</span>
        <span class="svc-sep" aria-hidden="true">/</span>
        <span class="svc-tag">Infrastructure</span>
        <span class="svc-sep" aria-hidden="true">/</span>
        <span class="svc-tag">MDM</span>
      </div>

      <div class="footer-divider" aria-hidden="true"></div>
    </div>

    <!-- Bottom: legal + copyright -->
    <div class="footer-bottom">
      <p class="copyright label">
        &copy; {currentYear} W&amp;S Technik GmbH. Alle Rechte vorbehalten.
      </p>

      <div class="legal-links">
        <a href="/impressum"    class="legal-link">Impressum</a>
        <a href="/datenschutz"  class="legal-link">Datenschutz</a>
        <a href="/kontakt"      class="legal-link">Kontakt</a>
      </div>
    </div>

    <!-- Decorative background text -->
    <div class="footer-bg-text" aria-hidden="true">WUS</div>

  </div>
</footer>

<style>
  .footer {
    background: var(--c-bg-footer);
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  /* Background green accent -->*/
  .footer::before {
    content: '';
    position: absolute;
    bottom: -20%;
    right: -10%;
    width: 50vw;
    height: 60vh;
    background: radial-gradient(ellipse, rgba(6, 78, 59, 0.2), transparent 70%);
    pointer-events: none;
  }

  .footer::after {
    content: '';
    position: absolute;
    top: -10%;
    left: -5%;
    width: 35vw;
    height: 40vh;
    background: radial-gradient(ellipse, rgba(4, 120, 87, 0.1), transparent 70%);
    pointer-events: none;
  }

  /* ── Footer inner ── */
  .footer-inner {
    justify-content: space-between;
    gap: 0;
    padding-top: 6vh;
    padding-bottom: 6vh;
    position: relative;
    z-index: 1;
  }

  /* ── Top row ── */
  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0;
    width: 100%;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-white);
    letter-spacing: 0.01em;
  }

  .brand-tagline {
    color: var(--c-muted);
  }

  /* ── Footer nav ── */
  .footer-nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .footer-nav-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-muted);
    transition: color var(--t-fast) var(--ease-out);
  }

  .footer-nav-link:hover {
    color: var(--c-green-4);
  }

  @media (max-width: 640px) {
    .footer-nav { display: none; }
  }

  /* ── Divider ── */
  .footer-divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--c-border-bright),
      rgba(16, 185, 129, 0.15),
      var(--c-border-bright),
      transparent
    );
    margin: 2.5rem 0;
  }

  /* ── Mid: company info ── */
  .footer-mid {
    width: 100%;
  }

  .footer-company {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 2rem;
  }

  @media (max-width: 768px) {
    .footer-company {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .company-primary {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .company-name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--c-white);
  }

  .company-role {
    color: var(--c-green-4);
  }

  /* ── Hierarchy indicator ── */
  .company-hierarchy {
    text-align: right;
  }

  @media (max-width: 768px) {
    .company-hierarchy { text-align: left; }
  }

  .hierarchy-line {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hierarchy-prefix {
    color: var(--c-muted);
  }

  .hierarchy-group {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--c-green-4);
    letter-spacing: 0.02em;
  }

  /* ── Services summary ── */
  .footer-services-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .svc-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--c-muted);
  }

  .svc-sep {
    color: var(--c-dim);
    font-size: 0.875rem;
  }

  /* ── Bottom: legal ── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .copyright {
    color: var(--c-dim);
  }

  .legal-links {
    display: flex;
    gap: 1.75rem;
  }

  .legal-link {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-dim);
    transition: color var(--t-fast) var(--ease-out);
  }

  .legal-link:hover {
    color: var(--c-muted);
  }

  /* ── Background watermark text ── */
  .footer-bg-text {
    position: absolute;
    bottom: -2vh;
    right: -2vw;
    font-family: var(--font-display);
    font-size: clamp(8rem, 18vw, 18rem);
    font-weight: 800;
    color: rgba(6, 78, 59, 0.06);
    letter-spacing: -0.05em;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    line-height: 1;
  }
</style>
