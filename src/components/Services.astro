---
/**
 * Services.astro — Section 2: "What We Do" (100vh)
 *
 * 4 service cards: DevOps / WebOps / Infrastructure / MDM
 * - Staggered scroll-triggered reveal (GSAP, src/scripts/sections.js)
 * - Per-card hover: border glow + CSS 3D perspective tilt (vanilla JS)
 * - SVG icons — custom geometric line icons
 */

const services = [
  {
    id: 'devops',
    title: 'DevOps',
    desc: 'CI/CD pipelines, container orchestration, and release automation for internal teams.',
    color: 'violet',
    icon: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="4" y="6" width="32" height="28" rx="3"/>
      <path d="M4 12h32"/>
      <circle cx="10" cy="9" r="1" fill="currentColor" stroke="none"/>
      <circle cx="14" cy="9" r="1" fill="currentColor" stroke="none"/>
      <circle cx="18" cy="9" r="1" fill="currentColor" stroke="none"/>
      <path d="M11 20l5 5-5 5M21 30h8"/>
    </svg>`,
  },
  {
    id: 'webops',
    title: 'WebOps',
    desc: 'Internal portals, tools, and web services. From design systems to production deploys.',
    color: 'green',
    icon: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="20" cy="20" r="15"/>
      <path d="M5 20h30"/>
      <path d="M20 5a22 22 0 010 30M20 5a22 22 0 000 30"/>
      <path d="M8 12h24M8 28h24"/>
    </svg>`,
  },
  {
    id: 'infrastructure',
    title: 'Infrastructure',
    desc: 'On-prem and hybrid cloud infrastructure, network architecture, and systems reliability.',
    color: 'violet',
    icon: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20 4l16 9v14L20 36 4 27V13L20 4z"/>
      <path d="M4 13l16 9M36 13l-16 9M20 22v14"/>
      <path d="M12 8.5l16 9"/>
    </svg>`,
  },
  {
    id: 'mdm',
    title: 'MDM',
    desc: 'Mobile Device Management — device policies, fleet enrollment, and endpoint compliance.',
    color: 'green',
    icon: `<svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20 3l14 6.5v11.5C34 28.5 27 35.5 20 38c-7-2.5-14-9.5-14-17V9.5L20 3z"/>
      <path d="M13 21l4 4 10-10"/>
    </svg>`,
  },
];
---

<section class="snap-section services" id="services" data-section="1">
  <div class="section-inner">

    <!-- Section header -->
    <div class="services-header">
      <span class="label label--accent services-label">/ 01</span>
      <h2 class="services-heading">What We Do</h2>
    </div>

    <!-- Cards grid -->
    <div class="services-grid">
      {services.map((service) => (
        <article
          class={`service-card service-card--${service.color}`}
          data-card
          id={`card-${service.id}`}
        >
          <!-- Icon container -->
          <div class={`card-icon-wrap card-icon-wrap--${service.color}`}>
            <Fragment set:html={service.icon} />
          </div>

          <!-- Text -->
          <h3 class="card-title">{service.title}</h3>
          <p class="card-desc">{service.desc}</p>

          <!-- Decorative corner accent -->
          <div class="card-corner" aria-hidden="true"></div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .services {
    background: var(--c-bg);
    display: flex;
    align-items: center;
  }

  /* ── Header ── */
  .services-header {
    margin-bottom: var(--sp-lg);
  }

  .services-label {
    display: block;
    margin-bottom: 0.75rem;
  }

  .services-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--c-white);
  }

  /* ── Grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .snap-section {
      height: auto;
      min-height: 100vh;
    }
  }

  /* ── Service Card ── */
  .service-card {
    position: relative;
    padding: 2rem 1.75rem 2.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--c-border);
    border-radius: 4px;
    cursor: default;
    transition:
      border-color var(--t-med) var(--ease-out),
      background var(--t-med) var(--ease-out),
      box-shadow var(--t-med) var(--ease-out),
      transform var(--t-med) var(--ease-out);
    /* perspective for 3D tilt — JS sets transform */
    transform-style: preserve-3d;
    will-change: transform;
    overflow: hidden;
  }

  /* Violet variant hover */
  .service-card--violet:hover {
    border-color: rgba(147, 51, 234, 0.4);
    background: rgba(107, 33, 168, 0.08);
    box-shadow:
      0 0 30px rgba(147, 51, 234, 0.12),
      0 0 60px rgba(107, 33, 168, 0.06),
      inset 0 0 20px rgba(147, 51, 234, 0.04);
  }

  /* Green variant hover */
  .service-card--green:hover {
    border-color: rgba(16, 185, 129, 0.35);
    background: rgba(6, 78, 59, 0.1);
    box-shadow:
      0 0 30px rgba(16, 185, 129, 0.1),
      0 0 60px rgba(6, 78, 59, 0.06),
      inset 0 0 20px rgba(16, 185, 129, 0.04);
  }

  /* ── Card Icon ── */
  .card-icon-wrap {
    width: 44px;
    height: 44px;
    margin-bottom: 1.75rem;
    color: var(--c-muted);
    transition: color var(--t-med) var(--ease-out);
  }

  .card-icon-wrap--violet {
    color: var(--c-violet-3);
  }

  .card-icon-wrap--green {
    color: var(--c-green-3);
  }

  .service-card:hover .card-icon-wrap--violet {
    color: var(--c-violet-5);
  }

  .service-card:hover .card-icon-wrap--green {
    color: var(--c-green-4);
  }

  .card-icon-wrap svg {
    width: 100%;
    height: 100%;
  }

  /* ── Card Text ── */
  .card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--c-white);
    margin-bottom: 0.75rem;
  }

  .card-desc {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.75;
    color: var(--c-muted);
  }

  /* ── Corner accent ── */
  .card-corner {
    position: absolute;
    top: 0;
    right: 0;
    width: 40px;
    height: 40px;
    border-left: 1px solid transparent;
    border-bottom: 1px solid transparent;
    transition: border-color var(--t-med) var(--ease-out);
  }

  .service-card--violet:hover .card-corner {
    border-color: rgba(147, 51, 234, 0.4);
  }

  .service-card--green:hover .card-corner {
    border-color: rgba(16, 185, 129, 0.35);
  }
</style>
