---
/**
 * HowWeWork.astro — Section 3: "How We Work" (100vh)
 *
 * 3-step horizontal process: Plan → Build → Ship
 * - Animated horizontal connecting line (CSS + GSAP)
 * - Steps reveal on scroll with GSAP stagger
 * - GSAP counter animation for step numbers
 */

const steps = [
  {
    number: '01',
    title: 'Plan',
    desc: 'Requirements, architecture, and sprint scoping with internal stakeholders. No guesswork.',
    accent: 'violet',
  },
  {
    number: '02',
    title: 'Build',
    desc: 'Iterative development with CI from day one. Every commit reviewed, every service observed.',
    accent: 'mixed',
  },
  {
    number: '03',
    title: 'Ship',
    desc: 'Zero-downtime deploys, runbooks, and handover. Production is the only environment that matters.',
    accent: 'green',
  },
];
---

<section class="snap-section how-we-work" id="how-we-work" data-section="2">
  <div class="section-inner">

    <!-- Section header -->
    <div class="hww-header">
      <span class="label label--green hww-label">/ 02</span>
      <h2 class="hww-heading">How We Work</h2>
    </div>

    <!-- Steps container -->
    <div class="steps-container">

      <!-- Horizontal track line -->
      <div class="track-line" aria-hidden="true">
        <div class="track-line-fill" id="track-fill"></div>
      </div>

      <!-- Step items -->
      {steps.map((step, i) => (
        <div class={`step-item step-item--${step.accent}`} data-step={i}>

          <!-- Node on the track -->
          <div class="step-node" aria-hidden="true">
            <div class="step-node-inner"></div>
          </div>

          <!-- Step number (GSAP counter target) -->
          <div class="step-number" aria-hidden="true">{step.number}</div>

          <!-- Content -->
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-desc">{step.desc}</p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .how-we-work {
    background: var(--c-bg-alt, #0d0d16);
    display: flex;
    align-items: center;
  }

  /* ── Header ── */
  .hww-header {
    margin-bottom: var(--sp-xl);
  }

  .hww-label {
    display: block;
    margin-bottom: 0.75rem;
  }

  .hww-heading {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--c-white);
  }

  /* ── Steps container ── */
  .steps-container {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  @media (max-width: 768px) {
    .steps-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .track-line {
      display: none;
    }
  }

  /* ── Horizontal track line ── */
  .track-line {
    position: absolute;
    top: 10px; /* aligns with node centers */
    left: calc(100% / 6); /* starts at first node center */
    right: calc(100% / 6); /* ends at last node center */
    height: 1px;
    background: var(--c-dim);
    z-index: 0;
  }

  .track-line-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, var(--c-violet-4), var(--c-green-4));
    transition: width 0.8s var(--ease-out);
  }

  /* ── Step item ── */
  .step-item {
    position: relative;
    padding: 0 2rem;
    padding-top: 2.5rem;
    z-index: 1;
  }

  .step-item:first-child { padding-left: 0; }
  .step-item:last-child  { padding-right: 0; }

  /* ── Node ── */
  .step-node {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-item:first-child .step-node { left: 0; transform: none; }
  .step-item:last-child  .step-node { left: auto; right: 0; transform: none; }

  .step-node-inner {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--c-dim);
    transition: background 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out);
  }

  .step-item--violet .step-node-inner {
    background: var(--c-violet-4);
    box-shadow: 0 0 12px rgba(147, 51, 234, 0.5);
  }

  .step-item--mixed .step-node-inner {
    background: linear-gradient(135deg, var(--c-violet-4), var(--c-green-4));
    box-shadow: 0 0 12px rgba(100, 100, 200, 0.4);
  }

  .step-item--green .step-node-inner {
    background: var(--c-green-4);
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.5);
  }

  /* ── Step number ── */
  .step-number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--c-dim);
    margin-bottom: 1rem;
    transition: color 0.4s var(--ease-out);
    user-select: none;
  }

  .step-item--violet .step-number { color: rgba(107, 33, 168, 0.4); }
  .step-item--mixed  .step-number { color: rgba(80, 80, 160, 0.35); }
  .step-item--green  .step-number { color: rgba(6, 78, 59, 0.45); }

  /* ── Step content ── */
  .step-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--c-white);
    margin-bottom: 0.875rem;
  }

  .step-desc {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.8;
    color: var(--c-muted);
    max-width: 280px;
  }
</style>
